{
  "name": "obsidian-mermaid-lens",
  "version": "0.2.0",
  "description": "Global Mermaid configuration and a pan/zoom viewer for Obsidian.",
  "main": "dist/main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build": "tsc --noEmit && node esbuild.config.mjs production",
    "deploy": "npm run build && node scripts/deploy.mjs"
  },
  "keywords": [
    "obsidian",
    "mermaid"
  ],
  "author": "aitsuki",
  "repository": "github:aitsuki/obsidian-mermaid-lens",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^4.1.10",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.28.1",
    "happy-dom": "^20.11.0",
    "obsidian": "latest",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  }
}
